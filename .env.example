# ─────────────────────────────────────────────────
# ResuFit — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # Server-only — never expose to client

# ── Stripe ────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...           # Server-only
STRIPE_WEBHOOK_SECRET=whsec_...         # Server-only

# Price IDs — one per product per currency
# One-time
STRIPE_PRICE_ONETIME_USD=price_...
STRIPE_PRICE_ONETIME_GBP=price_...
STRIPE_PRICE_ONETIME_EUR=price_...

# Pro monthly
STRIPE_PRICE_PRO_USD=price_...
STRIPE_PRICE_PRO_GBP=price_...
STRIPE_PRICE_PRO_EUR=price_...

# Annual
STRIPE_PRICE_ANNUAL_USD=price_...
STRIPE_PRICE_ANNUAL_GBP=price_...
STRIPE_PRICE_ANNUAL_EUR=price_...

# ── Anthropic ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...            # Server-only

# ── Resend (transactional email) ──────────────────
RESEND_API_KEY=re_...                   # Server-only
RESEND_FROM_EMAIL=hello@resufit.co

# ── Upstash Redis (rate limiting) ─────────────────
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ── App ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://resufit.co  # No trailing slash
NODE_ENV=production
